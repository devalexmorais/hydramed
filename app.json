{
  "expo": {
    "name": "HydraMed",
    "slug": "hydramed",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hydramed",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#0EA5E9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hydramed.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSNotificationUsageDescription": "HydraMed uses notifications to remind you to take your medications and stay hydrated."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0EA5E9"
      },
      "package": "com.hydramed.app"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "color": "#0EA5E9"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4209407061463021~3380277737",
          "iosAppId": "ca-app-pub-4209407061463021~2074934926"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dc227f2b-f03e-43ad-a2ab-43317cd31ff8"
      }
    }
  }
}
